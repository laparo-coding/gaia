# Gaia local-only environment overrides.
# Copy this file to .env.local and replace the placeholder with the real
# gaia project post_server_item token from Rollbar.
# Do not use the token's Public ID from the Rollbar UI and do not use a read
# token here; only a real post_server_item secret token can submit events.

GAIA_ROLLBAR_ACCESS_TOKEN=your-gaia-post-server-item-token

# Optional diagnostics and delivery tuning for local verification.
# GAIA_ROLLBAR_DIAGNOSTICS=true
# GAIA_ROLLBAR_DELIVERY_WAIT_SECONDS=1