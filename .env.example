# Shared Gaia example environment file.
# Keep real secrets in .env.local (ignored by git).

GAIA_ROLLBAR_ACCESS_TOKEN=your-gaia-post-server-item-token
# Optional:
# GAIA_ROLLBAR_DIAGNOSTICS=true
# GAIA_ROLLBAR_DELIVERY_WAIT_SECONDS=1

# Runtime selection: development | test | production
# GAIA_ENV=development

# Optional explicit service targets (URL with http/https).
# When not set, Gaia resolves defaults by runtime + Docker detection.
# GAIA_HEMERA_BASE_URL=http://127.0.0.1:3000
# GAIA_HEMERA_FALLBACK_BASE_URL=http://host.docker.internal:3000
# GAIA_AITHER_BASE_URL=http://127.0.0.1:3500
# GAIA_AITHER_FALLBACK_BASE_URL=http://host.docker.internal:3500
# AITHER_BASE_URL=http://127.0.0.1:3500

# Optional Docker runtime override for local testing/scripts (true/false).
# GAIA_DOCKER_RUNTIME=false
